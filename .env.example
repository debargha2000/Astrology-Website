# =============================================================================
# Aura & Stone — Environment Variables
# Copy to .env (local) and configure in your hosting platform (Vercel, etc.)
# =============================================================================

# Gemini API key (optional, for AI features)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public app URL (used for self-referential links, OAuth callbacks, API endpoints)
APP_URL="MY_APP_URL"

# REQUIRED: JWT signing secret (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# The server will refuse to start if this is missing or too short.
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_STRING"

# Razorpay payment gateway (required in production)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Admin email (the single authorized Google login account)
ADMIN_EMAIL="debarghapakhira@gmail.com"

# Gmail SMTP fallback (optional — primary path uses the user's OAuth token)
SMTP_USER=""
SMTP_PASS=""

# Firebase Admin SDK service account JSON (optional — falls back to local DB)
# When unset, the app uses the local flat-file `database.json` for persistence.
FIREBASE_SERVICE_ACCOUNT_KEY=""

# Firebase Web SDK (Vite — exposed to client; safe to be public but lock down via App Check)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Firebase App Check — reCAPTCHA Enterprise site key (recaptcha v3).
# Enables proof-of-work attestation for Firebase services. Recommended in production.
# Get one at https://console.cloud.google.com/security/recaptcha
VITE_FIREBASE_APPCHECK_SITE_KEY=""
