{
  "name": "ci",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation tsx server.ts",
    "build": "npm run build:schemas && npm run build:frontend && npm run build:server && npm run build:api",
    "build:schemas": "npm run build --prefix packages/schemas",
    "build:frontend": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "build:api": "esbuild api/index.src.ts --bundle --platform=node --format=esm --packages=external --outfile=api/index.js",
    "start": "node dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "eslint src server --ext .ts,.tsx",
    "lint:fix": "eslint src server --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"server/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"server/**/*.ts\""
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@aurastone/schemas": "file:./packages/schemas",
    "@google-cloud/vertexai": "^1.12.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.100.14",
    "@types/cors": "^2.8.19",
    "@types/react-router-dom": "^5.3.3",
    "@types/swagger-ui-express": "^4.1.8",
    "astronomy-engine": "^2.1.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.0.0",
    "firebase": "^11.1.0",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.2.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.469.0",
    "motion": "^11.15.0",
    "nodemailer": "^8.0.10",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^11.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.77.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.17.0",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.8",
    "axe-core": "^4.12.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.0",
    "workbox-window": "^7.4.1"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "uuid": "^11.1.1",
    "cookie": "^0.7.0",
    "gaxios": "^7.1.4",
    "google-gax": "^5.1.1-rc.1",
    "teeny-request": "^10.1.2",
    "retry-request": "^8.0.2",
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/storage": "^7.16.0"
  }
}
