{
  "name": "ci",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation tsx server.ts",
    "build": "npm run build:frontend && npm run build:server && npm run build:api",
    "build:frontend": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "build:api": "esbuild api/index.src.ts --bundle --platform=node --format=esm --packages=external --outfile=api/index.js",
    "start": "node dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "eslint src server --ext .ts,.tsx",
    "lint:fix": "eslint src server --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"server/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"server/**/*.ts\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.0.0",
    "firebase": "^11.1.0",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.2.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.469.0",
    "motion": "^11.15.0",
    "nodemailer": "^8.0.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "uuid": "^11.1.1",
    "cookie": "^0.7.0",
    "gaxios": "^7.1.4",
    "google-gax": "^5.1.1-rc.1",
    "teeny-request": "^10.1.2",
    "retry-request": "^8.0.2",
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/storage": "^7.16.0"
  }
}
